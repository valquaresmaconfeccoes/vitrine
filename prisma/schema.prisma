// ============================================================================
// Val Quaresma — Schema Prisma (v2 — com HeroSlide)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// CATEGORIAS
// ============================================================================
model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  image       String?
  order       Int      @default(0)
  active      Boolean  @default(true)

  products    Product[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([active, order])
  @@map("categories")
}

// ============================================================================
// PRODUTOS
// ============================================================================
model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @db.Text
  price       Decimal  @db.Decimal(10, 2)

  mainImage   String
  images      ProductImage[]

  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  active      Boolean  @default(true)
  featured    Boolean  @default(false)
  stock       Int?     @default(0)
  variants    Variant[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([active, featured])
  @@index([categoryId, active])
  @@map("products")
}

// ============================================================================
// IMAGENS DA GALERIA
// ============================================================================
model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String  @default("")
  order     Int     @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([productId, order])
  @@map("product_images")
}

// ============================================================================
// VARIAÇÕES
// ============================================================================
model Variant {
  id          String   @id @default(cuid())
  sku         String?  @unique
  name        String
  price       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  attributes  Json?

  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  active      Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId, active])
  @@map("variants")
}

// ============================================================================
// HERO SLIDES
// ============================================================================
// Sistema de banner dinâmico com agendamento e configurações avançadas.
//
// Lógica de exibição (em ordem de prioridade):
// 1. Slide deve estar `active: true`
// 2. Se tiver `startsAt`, deve ser >= agora
// 3. Se tiver `endsAt`, deve ser <= agora
// 4. Ordenados por `priority` (menor número = maior prioridade)
//
// Slide "permanente": sem startsAt/endsAt → sempre ativo (quando active=true)
// Slide "promocional": com startsAt/endsAt → aparece só no período definido
// ============================================================================
model HeroSlide {
  id          String   @id @default(cuid())

  // Conteúdo visual
  image       String                    // URL Cloudinary (obrigatória)
  title       String?                   // Título sobreposto (opcional)
  subtitle    String?                   // Subtítulo sobreposto (opcional)

  // CTA (call to action)
  buttonText  String?                   // Texto do botão (opcional)
  buttonUrl   String?                   // Link do botão (qualquer URL)
  buttonTarget HeroButtonTarget @default(SELF) // _self ou _blank

  // Aparência
  textColor   HeroTextColor @default(LIGHT)   // claro ou escuro

  // Comportamento do carrossel
  duration    Int      @default(5)      // segundos por slide (3-15)

  // Agendamento
  startsAt    DateTime?                 // null = sem restrição de início
  endsAt      DateTime?                 // null = sem restrição de fim

  // Controle
  priority    Int      @default(0)      // menor = aparece primeiro
  active      Boolean  @default(true)   // toggle manual rápido

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, priority])
  @@index([startsAt, endsAt])
  @@map("hero_slides")
}

enum HeroButtonTarget {
  SELF   // mesma aba
  BLANK  // nova aba
}

enum HeroTextColor {
  LIGHT  // texto branco (para fotos escuras)
  DARK   // texto preto (para fotos claras)
}

// ============================================================================
// USUÁRIO ADMIN
// ============================================================================
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(ADMIN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum Role {
  ADMIN
  STAFF
}
