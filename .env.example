# ============================================================================
# Val Quaresma — Variáveis de Ambiente
# ============================================================================
# Copie este arquivo para `.env` e preencha com valores reais.
# NUNCA commite o arquivo `.env` no Git (já está no .gitignore).
# ============================================================================

# ----------------------------------------------------------------------------
# BANCO DE DADOS (PostgreSQL — Railway)
# ----------------------------------------------------------------------------
# No Railway: depois de adicionar o plugin PostgreSQL,
# vá em Variables e copie a "DATABASE_URL" (Postgres Connection URL).
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:senha@localhost:5432/valquaresma"

# ----------------------------------------------------------------------------
# ADMIN INICIAL (usado apenas no seed)
# ----------------------------------------------------------------------------
# Estes valores criam o primeiro usuário admin quando você roda `npm run db:seed`.
# TROQUE a senha antes do primeiro deploy em produção!
ADMIN_EMAIL="val@valquaresma.com.br"
ADMIN_PASSWORD="ChangeMe@2026"

# ----------------------------------------------------------------------------
# AUTH (será usado nas próximas etapas — NextAuth)
# ----------------------------------------------------------------------------
# Gere com: openssl rand -base64 32
# (no Windows: use https://generate-secret.vercel.app/32)
NEXTAUTH_SECRET="gere-um-secret-forte-aqui"
NEXTAUTH_URL="http://localhost:3000"
